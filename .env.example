# 数据库配置
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=123456
DB_NAME=yxtyg_db
DB_CHARSET=utf8mb4

# 构造后的数据库URL（可选，如设置了 DB_HOST 等，程序会自动构造）
DATABASE_URL=mysql+pymysql://root:123456@127.0.0.1:3306/yxtyg_db?charset=utf8mb4

# 统一邮件中心
EMAIL_CENTER_URL=http://localhost:3210

# Obsidian 知识库路径
OBSIDIAN_VAULT_PATH=D:\\项目\\知识图谱

# 应用配置
APP_NAME=产品经理个人工作台
APP_VERSION=0.1.0
DEBUG=true
SECRET_KEY=your-secret-key-change-in-production

# 后端服务
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# 前端服务
FRONTEND_PORT=5173
